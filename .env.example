# Supabase Frontend Variables (Public)
VITE_SUPABASE_PROJECT_ID="your_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_publishable_key"
VITE_SUPABASE_URL="https://your_project_id.supabase.co"

# Supabase Edge Functions / Backend Variables (Private)
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"
DATABASE_URL="postgresql://postgres:your_db_password@hostname:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:your_db_password@hostname:5432/postgres"

# Third Party APIs
VITE_GOOGLE_AI_API_KEY="your_google_ai_key"

# Next.js fallback (if used over vite)
NEXT_PUBLIC_SUPABASE_URL="https://your_project_id.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your_publishable_key"
